---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';
import BaseLayout from './BaseLayout.astro';
import PostInteractions from '../components/PostInteractions';

type Props = CollectionEntry<'blog'>['data'] & {
  postId?: string;
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
  relatedPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, heroImage, tags, postId, prevPost, nextPost, relatedPosts } = Astro.props;
const ogImageUrl = postId && Astro.site ? new URL(`/og/${postId}.png`, Astro.site).toString() : undefined;
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description} ogImageUrl={ogImageUrl}>
  <article>
    {heroImage && (
      <div class="hero-image">
        <Image width={720} height={360} src={heroImage} alt="" />
      </div>
    )}
    <div class="post-header">
      <div class="meta">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span class="updated">（更新: <FormattedDate date={updatedDate} />）</span>
        )}
      </div>
      <h1>{title}</h1>
    </div>
    <hr />
    <div class="prose">
      <slot />
    </div>

    {tags && tags.length > 0 && (
      <div class="tags">
        {tags.map((tag: string) => (
          <a href={`/tags/${tag}/`} class="tag">#{tag}</a>
        ))}
      </div>
    )}

    {/* いいね・コメント */}
    <PostInteractions client:load slug={postId ?? ''} />


    {/* 前後の記事ナビゲーション */}
    <nav class="post-nav">
      <div class="post-nav-item prev">
        {prevPost && (
          <a href={`/blog/${prevPost.id}/`}>
            <span class="nav-label">← 前の記事</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        )}
      </div>
      <div class="post-nav-item next">
        {nextPost && (
          <a href={`/blog/${nextPost.id}/`}>
            <span class="nav-label">次の記事 →</span>
            <span class="nav-title">{nextPost.data.title}</span>
          </a>
        )}
      </div>
    </nav>

    {/* 関連記事 */}
    {relatedPosts && relatedPosts.length > 0 && (
      <section class="related">
        <h2>関連記事</h2>
        <ul>
          {relatedPosts.map((p) => (
            <li>
              <a href={`/blog/${p.id}/`}>
                <span class="related-title">{p.data.title}</span>
                <span class="related-date"><FormattedDate date={p.data.pubDate} /></span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* 一覧に戻る */}
    <div class="back-to-list">
      <a href="/">← 記事一覧へ</a>
    </div>
  </article>
</BaseLayout>

<style>
  .hero-image {
    margin-bottom: 2em;
  }
  .hero-image img {
    width: 100%;
    border-radius: 8px;
  }
  .post-header {
    margin-bottom: 1.5em;
  }
  .meta {
    font-size: 0.85em;
    color: rgb(var(--gray));
    margin-bottom: 0.6em;
  }
  .updated {
    margin-left: 0.5em;
  }
  h1 {
    font-size: 1.8em;
    line-height: 1.3;
    margin: 0;
  }
  hr {
    margin: 1.5em 0;
  }
  .prose {
    line-height: 1.8;
    color: rgb(var(--gray-dark));
  }

  /* タグ */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    margin-top: 1.5em;
  }
  .tag {
    font-size: 0.82em;
    color: rgb(var(--gray-dark));
    background: #fff;
    border: 1px solid rgb(var(--gray-light));
    padding: 0.25em 0.7em;
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .tag:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  /* いいね・コメント */
  :global(.post-interactions) {
    margin-top: 2em;
    padding-top: 1.5em;
    border-top: 1px solid rgb(var(--gray-light));
  }
  :global(.likes-area) {
    text-align: center;
    margin-bottom: 2em;
  }
  :global(.like-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.6em 1.4em;
    border: 2px solid #e91e8c;
    border-radius: 999px;
    background: #fff;
    color: #e91e8c;
    font-size: 1.1em;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }
  :global(.like-btn:hover) {
    background: #fce4f3;
    transform: scale(1.05);
  }
  :global(.like-btn.liked) {
    background: #fce4f3;
  }
  :global(.like-btn:active) {
    transform: scale(0.97);
  }
  :global(.heart-icon) {
    font-size: 1.3em;
  }
  :global(.like-count) {
    font-size: 1em;
  }
  :global(.comments-section) {
    margin-top: 0.5em;
  }
  :global(.comments-heading) {
    font-size: 1.1em;
    font-weight: 700;
    margin-bottom: 1em;
    color: rgb(var(--gray-dark));
  }
  :global(.comment-form) {
    display: flex;
    flex-direction: column;
    gap: 0.7em;
    margin-bottom: 1.5em;
    background: #f0f8ff;
    padding: 1.2em;
    border-radius: 12px;
    border: 1.5px solid #bae6fd;
  }
  :global(.comment-input),
  :global(.comment-textarea) {
    width: 100%;
    padding: 0.6em 0.9em;
    border: 1.5px solid #bae6fd;
    border-radius: 8px;
    font-size: 0.95em;
    font-family: inherit;
    background: #fff;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s;
  }
  :global(.comment-input:focus),
  :global(.comment-textarea:focus) {
    border-color: #38bdf8;
  }
  :global(.comment-textarea) {
    resize: vertical;
    min-height: 90px;
  }
  :global(.comment-error) {
    color: #dc2626;
    font-size: 0.88em;
    margin: 0;
  }
  :global(.comment-submit) {
    align-self: flex-end;
    padding: 0.55em 1.4em;
    background: #e91e8c;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.95em;
    font-weight: bold;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  :global(.comment-submit:hover) {
    opacity: 0.85;
  }
  :global(.comment-submit:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.no-comments) {
    text-align: center;
    color: rgb(var(--gray));
    font-size: 0.9em;
    padding: 1em 0;
  }
  :global(.comment-item) {
    padding: 1em 0;
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  :global(.comment-item:last-child) {
    border-bottom: none;
  }
  :global(.comment-meta) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4em;
  }
  :global(.comment-name) {
    font-weight: 600;
    font-size: 0.9em;
    color: #0369a1;
  }
  :global(.comment-date) {
    font-size: 0.8em;
    color: rgb(var(--gray));
  }
  :global(.comment-body) {
    margin: 0;
    font-size: 0.95em;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
  }


  /* 前後ナビ */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1em;
    margin-top: 1.5em;
    padding-top: 1em;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .post-nav-item a {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    padding: 0.8em 1em;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 6px;
    text-decoration: none;
    color: rgb(var(--gray-dark));
    transition: border-color 0.2s;
  }
  .post-nav-item a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .post-nav-item.next a {
    text-align: right;
  }
  .nav-label {
    font-size: 0.78em;
    color: rgb(var(--gray));
  }
  .nav-title {
    font-size: 0.9em;
    font-weight: 600;
    line-height: 1.4;
  }

  /* 関連記事 */
  .related {
    margin-top: 1.5em;
    padding-top: 1em;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .related h2 {
    font-size: 1em;
    color: rgb(var(--gray));
    margin: 0 0 1em 0;
    font-weight: 600;
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .related li {
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  .related li:last-child {
    border-bottom: none;
  }
  .related li a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
    padding: 0.8em 0;
    text-decoration: none;
    color: rgb(var(--gray-dark));
  }
  .related li a:hover .related-title {
    color: var(--accent);
  }
  .related-title {
    font-size: 0.92em;
  }
  .related-date {
    flex-shrink: 0;
    font-size: 0.8em;
    color: rgb(var(--gray));
  }

  /* 一覧に戻る */
  .back-to-list {
    margin-top: 1em;
    text-align: center;
  }
  .back-to-list a {
    font-size: 0.88em;
    color: rgb(var(--gray));
    text-decoration: none;
  }
  .back-to-list a:hover {
    color: var(--accent);
  }
</style>
