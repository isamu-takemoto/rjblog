---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/tags">Tags</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: white;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		max-width: 720px;
		margin: 0 auto;
		height: 56px;
	}
	.site-title {
		grid-column: 2;
		font-weight: 700;
		font-size: 1.1em;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.site-title:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.nav-links {
		grid-column: 3;
		display: flex;
		justify-content: flex-end;
		gap: 0.5em;
	}
	@media (max-width: 600px) {
		nav {
			display: flex;
			flex-direction: column;
			align-items: center;
			height: auto;
			padding: 0.8em 0;
			gap: 0.5em;
		}
		.nav-links {
			justify-content: center;
		}
	}
</style>
